{
  "name": "pinchtab-mcp-wrapper",
  "version": "0.4.0",
  "description": "MCP stdio server exposing Pinchtab browser API with token-efficient helpers",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node --test dist/**/*.test.js",
    "test:unit": "node --test dist/**/*.test.js",
    "test:integration": "node --test dist/**/*.integration.test.js",
    "test:e2e": "node --test dist/**/*.e2e.test.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "mcp",
    "browser",
    "automation",
    "ai",
    "agent",
    "pinchtab",
    "chromium"
  ],
  "author": "Platform / Agents Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "eslint": "^8.57.0",
    "typescript-eslint": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
