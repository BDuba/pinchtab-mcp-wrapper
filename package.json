{
  "name": "pinchtab-mcp-wrapper",
  "version": "0.5.1",
  "description": "MCP stdio server exposing Pinchtab browser API with token-efficient helpers",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:test": "tsc -p tsconfig.test.json",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=streamable-http node dist/index.js",
    "test": "node --test dist/**/*.test.js",
    "test:unit": "node --test dist/**/*.test.js",
    "test:integration": "npm run build:test && node --test dist-test/tests/integration/pinchtab.integration.test.js",
    "test:integration:http": "npm run build:test && node --test dist-test/tests/integration/streamable-http.integration.test.js",
    "test:e2e": "npm run build:test && node --test 'dist-test/tests/**/*.e2e.test.js'",
    "test:e2e:http": "npm run build:test && MCP_TRANSPORT=streamable-http node --test 'dist-test/tests/**/*.http.e2e.test.js'",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "mcp",
    "browser",
    "automation",
    "ai",
    "agent",
    "pinchtab",
    "chromium"
  ],
  "author": "Platform / Agents Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "eslint": "^8.57.0",
    "typescript-eslint": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
